 {  
    "layer":  "top", 
    "height": 0, 
    "margin-top": 5,
	"margin-right": 5,
	"margin-left": 5,
    "spacing": 0, 
    // Order Of Modules
    "modules-left": ["sway/workspaces", "sway/mode", "custom/mpris"],
    "modules-center": ["clock"],
    "modules-right": ["network", "bluetooth", "pulseaudio", "backlight", "battery", "tray"],

    // ---------- Configuring Modules -----------

    // Sway Workspaces module
    "sway/workspaces": {
	 "disable-scroll": true,
         "format": "{name}",
         "format-icons": {
             "urgent": "!!!",
             "focused": "´Çä",
             "default": "´Çä",
             "11": "VPN"
         }
     },
    
